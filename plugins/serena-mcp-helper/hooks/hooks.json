{
  "description": "Serena MCP Helper hooks - enforces Serena tools for .py and .tf files",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/serena_init_context.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Read|MultiEdit|Bash|Search|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/enforce_serena_tools.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
